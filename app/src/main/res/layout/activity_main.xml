<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:layout_marginTop="5dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!--    !!!Note của RelativeLayout(Bố cục tương đối)!!!
            android:layout_centerVertical="true": Nếu "true", căn giữa thành phần hiển thị con này theo chiều dọc trong thành phần hiển thị cha.
            android:layout_alignParentStart="true": Nếu "true", điều này sẽ làm cho cạnh bắt đầu của khung nhìn này trùng khớp với cạnh bắt đầu của khung nhìn cha.
            android:layout_centerInParent="true": Nếu "true", căn giữa phần tử con này theo chiều ngang và chiều dọc so với phần tử cha.-->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnBackToChoose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:backgroundTint="#444466"
                android:text="Quay lại"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="WISH IMPACT"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Thêm phần hiển thị User và Tiền ở góc phải -->
            <LinearLayout
                android:id="@+id/userSectionMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Icon Tiền tệ -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="4dp"/>

                <!-- Số tiền -->
                <TextView
                    android:id="@+id/tvTotalWishes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="15dp"/>

                <TextView
                    android:id="@+id/tvUserNameMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="5dp"/>

                <!-- Icon Customer -->
                <ImageView
                    android:id="@+id/imgUserIconMain"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_myplaces" />
            </LinearLayout>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dev by CreatorTeam"
            android:textColor="#888888"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:background="#2D2D44"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:srcCompat="@drawable/banner1" /> <!--dùng để hiển thị đó là ảnh ảo và có thể bị thay thế-->
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/btnHistory"
                android:text="@string/lich_su_quay"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"/>
            <ImageButton
                android:id="@+id/imgbtn_Inventory"
                android:layout_width="60dp"
                android:layout_height="50dp"
                android:text="inventory"
                android:background="#1E1E2E"
                android:scaleType="fitCenter"
                android:src="@drawable/img_inventory" />
            <ImageButton
                android:id="@+id/imgbtn_Shop"
                android:layout_width="60dp"
                android:layout_height="50dp"
                android:text="shop"
                android:background="#1E1E2E"
                android:scaleType="fitCenter"
                android:src="@drawable/img_shop"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:gravity="end">

                <Button
                    android:id="@+id/btnWish1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="#F48FB1"
                    android:text="Quay x1" />

                <Button
                    android:id="@+id/btnWish10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#AD1457"
                    android:text="Quay x10" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>