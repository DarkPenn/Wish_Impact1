<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2B3344"
    android:orientation="horizontal">

    <ScrollView
        android:id="@+id/layoutSidebarShop"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="16dp">

            <ImageButton

                android:id="@+id/imgbtnBack"
                android:layout_width="35dp"
                android:layout_height="50dp"
                android:background="@color/black"
                android:scaleType="fitCenter"
                android:src="@drawable/img_back" />

           <LinearLayout
               android:id="@+id/layoutFilterfollowstar"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:paddingVertical="16dp"
               >

               <View
                   android:layout_width="match_parent"
                   android:layout_height="1dp"
                   android:layout_marginVertical="12dp"
                   android:background="#444444" />
               <TextView
                   android:id="@+id/btnShopFilterAll"
                   android:layout_width="match_parent"
                   android:layout_height="40dp"
                   android:gravity="center"
                   android:text="Tất cả"
                   android:textColor="#FFFFFF"
                   android:textStyle="bold" />

               <TextView
                   android:id="@+id/btnShopFilter5"
                   android:layout_width="match_parent"
                   android:layout_height="40dp"
                   android:gravity="center"
                   android:text="5 ★"
                   android:textColor="#FFD700"
                   android:textStyle="bold" />

               <TextView
                   android:id="@+id/btnShopFilter4"
                   android:layout_width="match_parent"
                   android:layout_height="40dp"
                   android:gravity="center"
                   android:text="4 ★"
                   android:textColor="#A020F0"
                   android:textStyle="bold" />

               <TextView
                   android:id="@+id/btnShopFilter3"
                   android:layout_width="match_parent"
                   android:layout_height="40dp"
                   android:gravity="center"
                   android:text="3 ★"
                   android:textColor="#00BFFF"
                   android:textStyle="bold" />
           </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutFilterSort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#444444" />

            <TextView
                android:id="@+id/btnShopSortStarDesc"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Sao ↓ "
                android:textColor="#EAC587"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnShopSortStarAsc"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Sao ↑ "
                android:textColor="#EAC587"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnShopSortPriceDesc"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Giá ↓ "
                android:textColor="#EAC587"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnShopSortPriceAsc"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="Giá ↑ "
                android:textColor="#EAC587"
                android:textSize="12sp" />


        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Shop"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvShopMyMoney"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="#40000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Ví: 0 Bụi sao"
                android:textColor="#27A054"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvShopEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="không có sản phẩm nào được bán"
                android:textColor="#888888"
                android:textSize="18sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcvShopItems"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelBuyDetail"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:background="#ECE5D9"
        android:orientation="vertical"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D1C6AF"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="THÔNG TIN MUA HÀNG"
                android:textColor="#5A4F3D"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseShopPanel"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvBuyName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#333"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBuyStars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#CE7A46"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tvUnitPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="#8B7B66"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#CFC7B8" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Chọn số lượng mua:"
                android:textColor="#333"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBuyMinus"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:backgroundTint="#8B7B66"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBuyQuantity"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#333"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnBuyPlus"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:backgroundTint="#8B7B66"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Tổng tiền: 0"
                android:textColor="#D32F2F"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnConfirmBuy"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:backgroundTint="#27A054"
            android:text="MUA NGAY (BUY)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>